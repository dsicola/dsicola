# Copie para .env e preencha os valores reais:
#   cp .env.example .env

NODE_ENV=development
PORT=3000

# PostgreSQL (ajuste user, password, host, base)
DATABASE_URL=postgresql://user:password@localhost:5432/dsicola

# JWT — use segredos longos e aleatórios em produção (mín. 32 caracteres)
JWT_SECRET=change-me-min-32-chars-xxxxxxxxxxxxxxxx
JWT_REFRESH_SECRET=change-me-min-32-chars-yyyyyyyyyyyyyyyy
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS — origens do frontend (vírgula se várias)
FRONTEND_URL=http://localhost:5173

# ─── Logging (pino / tratamento de erros HTTP) ─────────────────────────────
# Nível: trace | debug | info | warn | error | fatal
# Em produção o default no código é "info" se não definir.
LOG_LEVEL=debug

# Em produção (NODE_ENV=production), por omissão os logs de falhas HTTP não incluem
# stack, corpo do pedido nem mensagens brutas de erros não operacionais (ex.: Prisma).
# Defina como true apenas para diagnóstico temporário em staging — não deixe ligado em produção estável.
# LOG_ERROR_DETAILS_IN_PRODUCTION=true
