  ministerioSuperior                String?       @map("ministerio_superior") // Ex: Ministério do Ensino Superior, Ciência, Tecnologia e Inovação
  decretoCriacao                    String?       @map("decreto_criacao") // Ex: Decreto n.º 7/09, de 12 de Maio
  nomeChefeDaa                      String?       @map("nome_chefe_daa") // Assinatura Chefe do DAA
  nomeDirectorGeral                 String?       @map("nome_director_geral") // Assinatura Director Geral
  localidadeCertificado             String?       @map("localidade_certificado") // Ex: Kuito
  cargoAssinatura1                  String?       @map("cargo_assinatura_1") // Ex: O CHEFE DO DAA
  cargoAssinatura2                  String?       @map("cargo_assinatura_2") // Ex: O DIRECTOR GERAL
  textoFechoCertificado             String?       @map("texto_fecho_certificado") // Ex: E por ser verdade, e me ter sido solicitado...
  textoRodapeCertificado            String?       @map("texto_rodape_certificado") // Ex: Departamento para os Assuntos Académicos de
  biComplementarCertificado         String?       @map("bi_complementar_certificado") // Ex: passado pelo Arquivo de Identificação competente
  labelMediaFinalCertificado        String?       @map("label_media_final_certificado") // Ex: Média Final da Licenciatura
  labelValoresCertificado           String?       @map("label_valores_certificado") // Ex: Valores
  tituloCertificadoSuperior         String?       @map("titulo_certificado_superior") // Ex: CERTIFICADO DE CONCLUSÃO (PDF dinâmico Superior)
  // Certificado Ensino Secundário (Angola - modelo II Ciclo / Certificado de Habilitações)
