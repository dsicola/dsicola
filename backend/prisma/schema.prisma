  governoProvincia                  String?       @map("governo_provincia") // Ex: GOVERNO DA PROVINCIA DE LUANDA
  escolaNomeNumero                 String?       @map("escola_nome_numero") // Ex: ESCOLA DO IIº CICLO DO ENSINO SECUNDÁRIO N° 5106 - NEVES & SOUSA
  ensinoGeral                       String?       @map("ensino_geral") // Ex: ENSINO GERAL
  tituloCertificadoSecundario       String?       @map("titulo_certificado_secundario") // Ex: CERTIFICADO DE HABILITAÇÕES
  textoFechoCertificadoSecundario   String?       @map("texto_fecho_certificado_secundario") // Ex: Por ser verdade e me ter sido pedido...
  cargoAssinatura1Secundario        String?       @map("cargo_assinatura_1_secundario") // Ex: O Subdirector Pedagógico
  cargoAssinatura2Secundario        String?       @map("cargo_assinatura_2_secundario") // Ex: A Directora
  nomeAssinatura1Secundario         String?       @map("nome_assinatura_1_secundario") // Ex: Dibanzilua Tando Jones
  nomeAssinatura2Secundario         String?       @map("nome_assinatura_2_secundario") // Ex: Madalena Galula César
  labelResultadoFinalSecundario     String?       @map("label_resultado_final_secundario") // Ex: Resultado final
  /// Selo/carimbo para PDF do certificado — Ensino Secundário (por instituição, multi-tenant)
  carimboCertificadoSecundarioUrl          String? @map("carimbo_certificado_secundario_url")
  carimboCertificadoSecundarioData         Bytes?  @map("carimbo_certificado_secundario_data")
  carimboCertificadoSecundarioContentType String? @map("carimbo_certificado_secundario_content_type")
  /// Selo/carimbo para documentos oficiais de conclusão — Ensino Superior (reservado p/preview/PDF futuros)
  carimboCertificadoSuperiorUrl           String? @map("carimbo_certificado_superior_url")
  carimboCertificadoSuperiorData          Bytes?  @map("carimbo_certificado_superior_data")
  carimboCertificadoSuperiorContentType    String? @map("carimbo_certificado_superior_content_type")
  /// Capa do hero no site público (ficheiro na BD); URL exposta via API e em landing_publico.heroImageUrl
  landingHeroPublicUrl              String?       @map("landing_hero_public_url")
  landingHeroPublicData            Bytes?        @map("landing_hero_public_data")
  landingHeroPublicContentType    String?       @map("landing_hero_public_content_type")
  // Site público (landing no subdomínio / domínio próprio): textos, imagens, redes — JSON sanitizado no backend
  landingPublico                  Json?         @map("landing_publico")
  // Notificações: o admin configura quais eventos enviam mensagem e por quais canais (email, telegram, sms)
  notificacaoConfig                Json?         @map("notificacao_config") // { triggers: { [key]: { enabled, canais } } }
  createdAt                   DateTime       @default(now()) @map("created_at")
  updatedAt                   DateTime       @updatedAt @map("updated_at")

  instituicao Instituicao? @relation(fields: [instituicaoId], references: [id])

  @@map("configuracoes_instituicao")
}

/// Imagens extra do site público (eventos, etc.) — servidas em URL pública por id
model LandingPublicUploadedImage {
