  numeroCopiasRecibo                 Int?          @default(1) @map("numero_copias_recibo") // 1-3 cópias (original + vias)
  nomeImpressoraPreferida            String?       @map("nome_impressora_preferida") // Lembrete: impressora selecionada na janela do navegador
