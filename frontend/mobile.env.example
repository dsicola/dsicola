# Exemplo para build da app móvel (Capacitor)
# Copie para .env.production ou exporte na CI antes de: npm run build:mobile
#
# OBRIGATÓRIO em produção: URL pública do backend (HTTPS).
# Sem isto, a app nativa não sabe onde está a API.
VITE_API_URL=https://api.seudominio.com

# Desenvolvimento com app num telemóvel na mesma rede Wi‑Fi:
# IP do computador onde corre o backend (não use "localhost" no telefone).
# VITE_CAPACITOR_DEV_API_HOST=192.168.1.10
