  faviconData                 Bytes?         @map("favicon_data")
  faviconContentType          String?        @map("favicon_content_type")
  imagemFundoDocumentoUrl     String?        @map("imagem_fundo_documento_url")
  imagemFundoDocumentoData    Bytes?         @map("imagem_fundo_documento_data")
  imagemFundoDocumentoContentType String?    @map("imagem_fundo_documento_content_type")
  corPrimaria                 String?        @map("cor_primaria")
  corSecundaria               String?        @map("cor_secundaria")
  corTerciaria                String?        @map("cor_terciaria")
  descricao                   String?
  email                       String?
