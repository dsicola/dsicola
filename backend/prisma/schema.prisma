  numeracaoAutomatica         Boolean        @default(true) @map("numeracao_automatica")
  moedaFaturacao              String?        @map("moeda_faturacao")
  percentualImpostoPadrao     Decimal?       @map("percentual_imposto_padrao") @db.Decimal(5, 2)
